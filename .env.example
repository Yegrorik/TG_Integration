# amoCRM Chats API credentials issued by amoCRM support after channel registration.
AMOCRM_CHAT_CHANNEL_ID=a4490ccc-5d7f-11e7-907b-a6006ad3dba0
AMOCRM_CHAT_CHANNEL_SECRET=da39a3ee5e6b4b0d3255bfef95601890afd80709
AMOCRM_CHAT_SCOPE_ID=f90ba33d-c9d9-44da-b76c-c349b0ecbe41_af9945ff-1490-4cad-807d-945c15d88bec

# Use https://amojo.amocrm.com for *.amocrm.com accounts.
AMOCRM_CHAT_BASE_URL=https://amojo.amocrm.ru

# Display name used by /amocrm/chats/connect when title is omitted.
AMOCRM_CHAT_DEFAULT_TITLE=TG Integration

# Optional: regular amoCRM REST API settings for lead event fallback.
AMOCRM_ACCOUNT_BASE_URL=https://example.amocrm.ru
AMOCRM_ACCESS_TOKEN=long-lived-or-refreshed-oauth-access-token

TELEGRAM_BOT_TOKEN=123456:ABCDEF-your-token
TELEGRAM_WEBHOOK_SECRET=generate-a-random-32-char-string
TELEGRAM_API_BASE_URL=https://api.telegram.org

# Public HTTPS URL of this service, without trailing slash.
PUBLIC_BASE_URL=https://your-domain.com

# Local bridge state: conversation mapping, processed webhook ids, message links.
BRIDGE_DB_PATH=data/bridge.sqlite3

# Safer default: Telegram media is converted to text notes.
# Turn on only if you accept that Telegram file URLs contain your bot token.
TELEGRAM_EXPOSE_FILE_URLS=false
